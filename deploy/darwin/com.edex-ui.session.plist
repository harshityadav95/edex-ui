<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN"
    "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <key>Label</key>
    <string>__EDEX_SESSION_LABEL__</string>
    <key>ProgramArguments</key>
    <array>
        <string>__EDEX_SESSION_RUNNER__</string>
    </array>
    <key>RunAtLoad</key>
    <true/>
    <key>KeepAlive</key>
    <true/>
    <key>LimitLoadToSessionType</key>
    <string>Aqua</string>
    <key>StandardOutPath</key>
    <string>__EDEX_LOG_DIR__/session.out.log</string>
    <key>StandardErrorPath</key>
    <string>__EDEX_LOG_DIR__/session.err.log</string>
</dict>
</plist>
