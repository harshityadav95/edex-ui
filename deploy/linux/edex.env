# eDEX-UI LAN service defaults.
# Install this file to /etc/edex-ui/edex.env and adjust locally as needed.

EDEX_USER=edex
EDEX_APP_DIR=/opt/edex-ui
EDEX_HOME=/var/lib/edex-ui

EDEX_DISPLAY=:1
EDEX_RESOLUTION=1600x900
EDEX_DEPTH=24
EDEX_DISPLAY_BACKEND=auto

# "auto" prefers KasmVNC when installed, otherwise falls back to x11vnc/noVNC.
# Set to "novnc" for the distro-only stack, or "kasm" to require KasmVNC.
EDEX_VNC_STACK=auto
EDEX_VNC_PORT=5901
EDEX_NOVNC_HOST=127.0.0.1
EDEX_NOVNC_PORT=6080
EDEX_WEB_PORT=8443

EDEX_NODE_ENV=production
EDEX_ELECTRON_FLAGS=--nointro --no-sandbox

# Optional app tuning.
EDEX_DISABLE_AUDIO=false
EDEX_THEME=tron

