# eDEX-UI LAN service defaults.
# Install this file to /etc/edex-ui/edex.env and adjust locally as needed.

EDEX_USER=edex
EDEX_APP_DIR=/opt/edex-ui
EDEX_HOME=/var/lib/edex-ui

EDEX_DISPLAY=:1
EDEX_RESOLUTION=1600x900
EDEX_DEPTH=24
EDEX_DISPLAY_BACKEND=auto

# "novnc" is the distro-only stack used by this service profile.
# Set to "auto" to prefer KasmVNC when installed, or "kasm" to require KasmVNC.
EDEX_VNC_STACK=novnc
EDEX_VNC_PORT=5901
EDEX_NOVNC_HOST=127.0.0.1
EDEX_NOVNC_PORT=6080
EDEX_WEB_PORT=8443
EDEX_SSL_CERT=/etc/ssl/certs/ssl-cert-snakeoil.pem
EDEX_SSL_KEY=/etc/ssl/private/ssl-cert-snakeoil.key
EDEX_HTPASSWD_FILE=/etc/nginx/edex.htpasswd

# Optional public hostname used only for operator URL output.
# Example: EDEX_PUBLIC_HOSTNAME=edex.example.com
EDEX_PUBLIC_HOSTNAME=

EDEX_NODE_ENV=production
EDEX_ELECTRON_FLAGS="--no-sandbox"

# Optional app tuning.
EDEX_DISABLE_AUDIO=false
EDEX_THEME=tron
