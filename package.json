{
  "name": "edex-ui",
  "productName": "eDEX-UI",
  "version": "2.2.8",
  "description": "A science fiction desktop service for macOS and Debian/Ubuntu Linux.",
  "keywords": [
    "desktop",
    "sci-fi",
    "gui",
    "macos",
    "linux",
    "debian",
    "ubuntu",
    "service",
    "tty",
    "terminal"
  ],
  "main": "src/_boot.js",
  "engines": {
    "node": ">=22.12.0"
  },
  "packageManager": "pnpm@9.0.0",
  "scripts": {
    "start": "electron src --nointro",
    "install-linux": "pnpm install && cd src && pnpm install && cd .. && pnpm run rebuild-native",
    "install-darwin": "pnpm install && cd src && pnpm install && cd .. && pnpm run rebuild-native",
    "rebuild-native": "electron-rebuild -f -w node-pty -m src",
    "prebuild-darwin": "rsync -a src/ prebuild-src --exclude node_modules && node prebuild-minify.js && cd prebuild-src && pnpm install",
    "prebuild-darwin-arm64": "pnpm run prebuild-darwin",
    "build-darwin": "./node_modules/.bin/electron-builder build -m --universal -c.mac.identity=null -c.forceCodeSigning=false",
    "build-darwin-signed": "./node_modules/.bin/electron-builder build -m --universal -c.forceCodeSigning=true",
    "build-darwin-arm64": "./node_modules/.bin/electron-builder build -m --arm64 -c.mac.identity=null -c.forceCodeSigning=false",
    "build-darwin-arm64-signed": "./node_modules/.bin/electron-builder build -m --arm64 -c.forceCodeSigning=true",
    "postbuild-darwin": "rm -R prebuild-src",
    "test": "rsync -a --info=progress2 src/ prebuild-src --exclude node_modules && node prebuild-minify.js && cd prebuild-src && pnpm install && snyk test && cd .. && rm -R prebuild-src",
    "test:linux-service": "bash scripts/test-linux-service-spec.sh",
    "test:darwin-service": "bash scripts/test-darwin-service-spec.sh",
    "test:platform-support": "bash scripts/test-platform-support-spec.sh",
    "service-controller-darwin": "electron src/darwin-service-controller.js",
    "init-file-icons": "git submodule update --init",
    "update-file-icons": "git submodule foreach git pull origin master && node file-icons-generator.js"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/GitSquared/edex-ui.git"
  },
  "author": "Gabriel 'Squared' SAILLARD <gabriel@saillard.dev> (https://gaby.dev)",
  "license": "GPL-3.0",
  "os": [
    "darwin",
    "linux"
  ],
  "bugs": {
    "url": "https://github.com/GitSquared/edex-ui/issues"
  },
  "homepage": "https://github.com/GitSquared/edex-ui#readme",
  "build": {
    "appId": "com.edex.ui",
    "productName": "eDEX-UI",
    "publish": "github",
    "asar": true,
    "compression": "normal",
    "copyright": "Copyright © 2017-2021 Gabriel 'Squared' SAILLARD <gabriel@saillard.dev> (https://gaby.dev)",
    "directories": {
      "output": "dist",
      "app": "prebuild-src"
    },
    "forceCodeSigning": false,
    "npmRebuild": true,
    "artifactName": "eDEX-UI-${os}-${arch}.${ext}",
    "mac": {
      "target": [
        {
          "target": "dmg",
          "arch": [
            "universal"
          ]
        }
      ],
      "category": "public.app-category.utilities",
      "icon": "media/icon.icns",
      "x64ArchFiles": "**/node_modules/{@napi-rs/canvas-darwin-*,node-pty/prebuilds/darwin-*}/**/*"
    },
    "dmg": {
      "artifactName": "eDEX-UI-macOS-${arch}.dmg"
    }
  },
  "dependencies": {
    "@electron/rebuild": "4.0.4",
    "clean-css": "5.3.3",
    "electron": "42.0.1",
    "electron-builder": "26.8.1",
    "mime-types": "3.0.2",
    "node-json-minify": "3.0.0",
    "terser": "5.47.1"
  },
  "optionalDependencies": {
    "cson-parser": "4.0.9"
  },
  "overrides": {
    "ajv": "6.15.0",
    "minimatch@3.1.5": {
      "brace-expansion": "1.1.14"
    }
  }
}
